# Acla Viglia Radons — benötigte Umgebungsvariablen
# In Vercel unter Settings -> Environment Variables setzen (Production + Preview).
# Lokal als .env.local (gitignored).

# Passwort für den Admin-Bereich /verwaltung (Angela + Marco).
ADMIN_PASSWORD=

# Zufälliges Geheimnis zum Signieren des Login-Cookies.
# Erzeugen mit: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=

# Wird automatisch gesetzt, sobald ein Vercel Blob Store mit dem Projekt
# verbunden ist (Speicher für die Buchungen). Lokal nicht nötig
# (Dev-Fallback schreibt nach .data/bookings.json).
BLOB_READ_WRITE_TOKEN=
